{
  "extends": "@arduino-lab/tsconfig/library.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    // The HTTP client is built on fetch/URL/AbortSignal, so DOM typings are
    // required even though the schemas themselves are environment-agnostic.
    "lib": ["ES2023", "DOM"],
    "outDir": "dist",
    "rootDir": "src",
    // Kept inside dist so `rimraf dist` also resets the incremental build state;
    // otherwise a stale tsbuildinfo makes tsc emit nothing after a dist wipe.
    "tsBuildInfoFile": "dist/.tsbuildinfo"
  },
  "include": ["src/**/*"]
}
