{
  "extends": "@arduino-lab/tsconfig/react-library.json",
  "compilerOptions": {
    // Source-shipped package: Next.js transpiles it via transpilePackages, so
    // nothing is emitted here and only type checking runs.
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["react", "react-dom"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
