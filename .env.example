# ══════════════════════════════════════════════════════════════
#  Arduino Lab — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env — it is git-ignored.
# ══════════════════════════════════════════════════════════════

# ─── Database (Neon PostgreSQL) ────────────────────────────────
# Pooled connection — used by the app at runtime
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/arduino_lab?sslmode=require"
# Direct connection — used by Prisma Migrate only
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/arduino_lab?sslmode=require"

# ─── API server ────────────────────────────────────────────────
NODE_ENV="development"
PORT="4000"
API_URL="http://localhost:4000"

# ─── JWT ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET="replace-with-48-random-bytes"
JWT_REFRESH_SECRET="replace-with-a-different-48-random-bytes"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ─── Allowed student email domains (comma separated) ───────────
ALLOWED_EMAIL_DOMAINS="student.university.edu.eg,university.edu.eg"

# ─── CORS: front-end origins allowed to call the API ───────────
STUDENT_APP_URL="http://localhost:3000"
ADMIN_APP_URL="http://localhost:3001"

# ─── Cloudinary (ID card images) ───────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_UPLOAD_FOLDER="arduino-lab/id-cards"

# ─── Resend (transactional email) ──────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
MAIL_FROM="Arduino Lab <noreply@yourdomain.com>"

# ─── Bootstrap admin (created by pnpm db:seed) ─────────────────
SEED_ADMIN_EMAIL="admin@university.edu.eg"
SEED_ADMIN_PASSWORD="change-this-immediately"
SEED_ADMIN_NAME="System Administrator"

# ══════════════════════════════════════════════════════════════
#  Front-end apps (apps/student/.env.local & apps/admin/.env.local)
#  NEXT_PUBLIC_* values are exposed to the browser — no secrets.
# ══════════════════════════════════════════════════════════════
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
